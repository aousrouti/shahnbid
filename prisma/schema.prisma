// ShahnBid data model — SQL Server (Express) target.
//
// Provider is sqlserver for now; the user may switch to postgresql later. To keep
// that switch cheap, this schema sticks to the portable subset:
//   - enums are modeled as String (SQL Server has no native enum in Prisma)
//   - the photo list is stored as a JSON string (no scalar arrays on SQL Server)
//   - string keys / indexed string columns are length-bounded (SQL Server caps
//     index keys at 900 bytes; unbounded NVARCHAR(1000) keys would overflow)
//
// The app already validates these string fields against TS unions, so String
// columns are safe. Allowed values are noted in comments next to each field.
//
// Bring-up:
//   1. Enable TCP/IP + mixed-mode auth, create the `shahnbid` DB + login (elevated script).
//   2. Set DATABASE_URL in .env.local.
//   3. npx prisma migrate dev --name init
//   4. Repo layer (lib/server/*-repo.ts) swaps from the in-memory maps to `prisma`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Accounts ──────────────────────────────

// Flat account table matching the app's PublicAccount shape (client- and
// carrier-specific fields are nullable columns). Simpler 1:1 mapping than a
// normalized split, and the app already validates each field against TS unions.
model Profile {
  id           String   @id @db.NVarChar(50)
  role         String   @db.NVarChar(20)   // CLIENT | CARRIER | ADMIN
  email        String   @unique @db.NVarChar(255)
  passwordHash String   @db.NVarChar(255)
  fullName     String   @db.NVarChar(200)
  phone        String?  @db.NVarChar(40)
  country      String?  @db.NVarChar(100)
  city         String?  @db.NVarChar(100)
  // Client-only
  clientType   String?  @db.NVarChar(20)   // INDIVIDUAL | BUSINESS
  companyName  String?  @db.NVarChar(200)
  ice          String?  @db.NVarChar(20)
  address      String?  @db.NVarChar(400)
  // Carrier-only
  status          String?   @db.NVarChar(20)   // PENDING | APPROVED | REJECTED | SUSPENDED
  licenseNumber   String?   @db.NVarChar(100)
  insuranceExpiry String?   @db.NVarChar(40)
  createdAt    DateTime @default(now())

  jobs          Job[]                 @relation("ClientJobs")
  bids          Bid[]                 @relation("CarrierBids")
  returnTrips   ReturnTrip[]          @relation("CarrierReturns")
  pushSubs      PushSubscription[]
  notifications Notification[]

  @@index([role])
  @@index([status])
}

// ──────────────────────────── Marketplace ────────────────────────────

model Job {
  id             String    @id @db.NVarChar(50)
  client         Profile   @relation("ClientJobs", fields: [clientId], references: [id])
  clientId       String    @db.NVarChar(50)
  source         String    @default("CLIENT_POSTED") @db.NVarChar(20)  // CLIENT_POSTED | RETURN_TRIP
  status         String    @default("PUBLISHED") @db.NVarChar(20)      // DRAFT|PUBLISHED|ACCEPTED|PICKED_UP|IN_TRANSIT|DELIVERED|COMPLETED|CANCELLED
  cargoType      String    @db.NVarChar(20)   // GENERAL|REFRIGERATED|HAZMAT|FRAGILE|OVERSIZED|LIVESTOCK
  description    String    @db.NVarChar(Max)
  weightKg       Int
  fragile        Boolean   @default(false)
  hazmat         Boolean   @default(false)
  originCity     String    @db.NVarChar(100)
  originAddress  String    @db.NVarChar(400)
  destCity       String    @db.NVarChar(100)
  destAddress    String    @db.NVarChar(400)
  pickupDateFrom DateTime
  pickupDateTo   DateTime?
  deliveryDate   DateTime
  notes          String?   @db.NVarChar(Max)
  photoUrls      String    @default("[]") @db.NVarChar(Max)  // JSON array of URLs

  // Set when a bid is accepted. The rate is snapshotted so later pricing
  // changes never rewrite historical earnings. acceptedBidId is a plain column
  // (SQL Server UNIQUE allows only one NULL row, which would break multi-job inserts).
  agreedPriceMAD        Int?
  acceptedBidId         String? @db.NVarChar(50)
  commissionRateSnap    Float?
  commissionCapturedMAD Int?
  paymentRef            String? @db.NVarChar(100)   // provider intent ref (stub/Stripe)
  paymentStatus         String? @db.NVarChar(20)    // AUTHORIZED | CAPTURED | FAILED

  bids      Bid[]    @relation("JobBids")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([clientId])
  @@index([originCity, destCity])
}

model Bid {
  id          String   @id @db.NVarChar(50)
  job         Job      @relation("JobBids", fields: [jobId], references: [id], onDelete: Cascade)
  jobId       String   @db.NVarChar(50)
  carrier     Profile  @relation("CarrierBids", fields: [carrierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  carrierId   String   @db.NVarChar(50)
  priceMAD    Int
  etaDays     Int
  vehicleType String   @db.NVarChar(60)
  notes       String?  @db.NVarChar(Max)
  status      String   @default("PENDING") @db.NVarChar(20)   // PENDING | ACCEPTED | REJECTED | WITHDRAWN
  createdAt   DateTime @default(now())

  @@unique([jobId, carrierId]) // one active bid per carrier per job
  @@index([carrierId])
  @@index([status])
}

model ReturnTrip {
  id             String   @id @db.NVarChar(50)
  carrier        Profile  @relation("CarrierReturns", fields: [carrierId], references: [id])
  carrierId      String   @db.NVarChar(50)
  originCity     String   @db.NVarChar(100)
  destCity       String   @db.NVarChar(100)
  availableDate  DateTime
  capacityKg     Int
  vehicleType    String   @db.NVarChar(60)
  listedPriceMAD Int
  notes          String?  @db.NVarChar(Max)
  status         String   @default("OPEN") @db.NVarChar(20)   // OPEN | BOOKED | EXPIRED | CANCELLED
  createdAt      DateTime @default(now())

  @@index([status])
  @@index([originCity, destCity])
}

// ───────────────────────────── Platform ──────────────────────────────

// Single-row table holding the admin-editable pricing rules.
model PricingSettings {
  id               Int      @id @default(1)
  commissionRate   Float    @default(0.10)
  minCommissionMAD Int      @default(50)
  vatRate          Float    @default(0.20)
  minJobPriceMAD   Int      @default(100)
  commissionPayer  String   @default("CARRIER") @db.NVarChar(20)  // CARRIER | CLIENT
  updatedBy        String   @default("système") @db.NVarChar(255)
  updatedAt        DateTime @updatedAt
}

model AdminNotification {
  id        String   @id @db.NVarChar(50)
  type      String   @db.NVarChar(30)   // NEW_CARRIER | NEW_CLIENT
  title     String   @db.NVarChar(200)
  body      String   @db.NVarChar(Max)
  link      String   @db.NVarChar(400)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
}

// Per-user in-app notification feed (clients and carriers alike).
model Notification {
  id        String   @id @db.NVarChar(50)
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @db.NVarChar(50)
  type      String   @db.NVarChar(40)
  title     String   @db.NVarChar(200)
  body      String   @db.NVarChar(Max)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model PushSubscription {
  id        String   @id @default(cuid()) @db.NVarChar(50)
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @db.NVarChar(50)
  endpoint  String   @db.NVarChar(Max)   // browser endpoint URLs can exceed index-key limits
  p256dh    String   @db.NVarChar(Max)
  auth      String   @db.NVarChar(200)
  createdAt DateTime @default(now())

  @@index([userId])
}
