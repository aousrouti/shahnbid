// ShahnBid data model — PostgreSQL (Neon / Vercel Postgres).
//
// Migrated from SQL Server: provider is now postgresql and the SQL-Server-specific
// @db.NVarChar(...) annotations are removed (Postgres String → text, no 900-byte
// index limit). Enums stay as String and the photo list stays a JSON string, so the
// data-access layer (lib/server/*-repo.ts) is unchanged.
//
// Bring-up:
//   1. Create a Neon project (free) and copy its connection string.
//   2. Set DATABASE_URL in .env (and on Vercel). For serverless, use Neon's pooled
//      string, e.g. ...-pooler.../db?sslmode=require&connection_limit=1
//   3. npx prisma db push   (or migrate dev)
//   4. npx tsx prisma/seed.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (runtime / serverless)
  directUrl = env("DIRECT_URL")   // direct (migrations / db push)
}

// ───────────────────────────── Accounts ──────────────────────────────

model Profile {
  id           String   @id
  role         String   // CLIENT | CARRIER | ADMIN
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  country      String?
  city         String?
  // Client-only
  clientType   String?  // INDIVIDUAL | BUSINESS
  companyName  String?
  ice          String?
  address      String?
  // Carrier-only
  status          String?   // PENDING | APPROVED | REJECTED | SUSPENDED
  licenseNumber   String?
  insuranceExpiry String?
  // Notification channel preferences (WhatsApp off by default — opt-in/consent)
  notifyInApp     Boolean   @default(true)
  notifyEmail     Boolean   @default(true)
  notifyWhatsapp  Boolean   @default(false)
  acceptedTermsAt DateTime?
  createdAt    DateTime @default(now())

  jobs          Job[]                 @relation("ClientJobs")
  bids          Bid[]                 @relation("CarrierBids")
  returnTrips   ReturnTrip[]          @relation("CarrierReturns")
  pushSubs      PushSubscription[]
  notifications Notification[]

  @@index([role])
  @@index([status])
}

// ──────────────────────────── Marketplace ────────────────────────────

model Job {
  id             String    @id
  client         Profile   @relation("ClientJobs", fields: [clientId], references: [id])
  clientId       String
  source         String    @default("CLIENT_POSTED") // CLIENT_POSTED | RETURN_TRIP
  status         String    @default("PUBLISHED")     // DRAFT|PUBLISHED|ACCEPTED|PICKED_UP|IN_TRANSIT|DELIVERED|COMPLETED|CANCELLED
  cargoType      String    // GENERAL|REFRIGERATED|HAZMAT|FRAGILE|OVERSIZED|LIVESTOCK
  description    String
  weightKg       Int
  fragile        Boolean   @default(false)
  hazmat         Boolean   @default(false)
  originCity     String
  originAddress  String
  destCity       String
  destAddress    String
  pickupDateFrom DateTime
  pickupDateTo   DateTime?
  deliveryDate   DateTime
  notes          String?
  photoUrls      String    @default("[]") // JSON array of URLs

  agreedPriceMAD        Int?
  acceptedBidId         String?
  commissionRateSnap    Float?
  commissionCapturedMAD Int?
  paymentRef            String?
  paymentStatus         String?   // AUTHORIZED | CAPTURED | FAILED

  bids      Bid[]    @relation("JobBids")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([clientId])
  @@index([originCity, destCity])
}

model Bid {
  id          String   @id
  job         Job      @relation("JobBids", fields: [jobId], references: [id], onDelete: Cascade)
  jobId       String
  carrier     Profile  @relation("CarrierBids", fields: [carrierId], references: [id])
  carrierId   String
  priceMAD    Int
  etaDays     Int
  vehicleType String
  notes       String?
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN
  createdAt   DateTime @default(now())

  @@unique([jobId, carrierId]) // one active bid per carrier per job
  @@index([carrierId])
  @@index([status])
}

model ReturnTrip {
  id             String   @id
  carrier        Profile  @relation("CarrierReturns", fields: [carrierId], references: [id])
  carrierId      String
  originCity     String
  destCity       String
  availableDate  DateTime
  capacityKg     Int
  vehicleType    String
  listedPriceMAD Int
  notes          String?
  status         String   @default("OPEN") // OPEN | BOOKED | EXPIRED | CANCELLED
  createdAt      DateTime @default(now())

  @@index([status])
  @@index([originCity, destCity])
}

// ───────────────────────────── Platform ──────────────────────────────

model PricingSettings {
  id               Int      @id @default(1)
  commissionRate   Float    @default(0.10)
  minCommissionMAD Int      @default(50)
  vatRate          Float    @default(0.20)
  minJobPriceMAD   Int      @default(100)
  commissionPayer  String   @default("CARRIER") // CARRIER | CLIENT
  updatedBy        String   @default("système")
  updatedAt        DateTime @updatedAt
}

model AdminNotification {
  id        String   @id
  type      String   // NEW_CARRIER | NEW_CLIENT | NEW_JOB | NEW_BID
  title     String
  body      String
  link      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
}

// Per-user in-app notification feed (clients and carriers alike).
model Notification {
  id        String   @id
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model PushSubscription {
  id        String   @id @default(cuid())
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
